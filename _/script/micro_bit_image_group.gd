		_init_chat_to_image()

static func set_or_append_key_to_image(key:String, image:String):
	check_that_it_is_initialized()
	char_to_image[key] = image

static func get_text_image_for_char_key(key:String)->String:
	check_that_it_is_initialized()
	if not char_to_image.has(key):
		return IMAGE_EMPTY
	return char_to_image[key]


